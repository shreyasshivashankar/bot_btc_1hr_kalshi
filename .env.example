# ============================================================================
# bot_btc_1hr_kalshi — LOCAL DEV env template
# ============================================================================
# Copy to `.env` and fill in. NEVER commit the populated .env.
# In cloud, these same vars are set via deploy/env.yaml (non-secrets)
# and Secret Manager (secrets). This file is local-only.
# ============================================================================

# ---- Deployment mode ---------------------------------------------------------
BOT_BTC_1HR_KALSHI_MODE=paper                        # paper | shadow | live
BOT_BTC_1HR_KALSHI_ENV=dev                           # dev | staging | prod

# ---- GCP context (auto-populated on Cloud Run; set manually locally) --------
BOT_BTC_1HR_KALSHI_GCP_PROJECT=
BOT_BTC_1HR_KALSHI_GCP_REGION=us-central1
BOT_BTC_1HR_KALSHI_SERVICE_NAME=bot-btc-1hr-kalshi

# ---- Kalshi credentials (in Cloud Run these come from Secret Manager) -------
# API_KEY is the UUID shown in the Kalshi dashboard — not a secret, but
# paired with PRIVATE_KEY_PATH to sign REST + WS requests.
# PRIVATE_KEY_PATH points to the PEM file on disk. Locally this is wherever
# you saved the key; on Cloud Run the secret is mounted as a file and the
# env var points at the mount path (see deploy/cloudrun.yaml).
BOT_BTC_1HR_KALSHI_API_KEY=
BOT_BTC_1HR_KALSHI_PRIVATE_KEY_PATH=
BOT_BTC_1HR_KALSHI_WS_URL=wss://api.elections.kalshi.com/trade-api/ws/v2
BOT_BTC_1HR_KALSHI_REST_URL=https://api.elections.kalshi.com/trade-api/v2

# ---- Admin (bearer token for /admin/* HTTP endpoints) -----------------------
BOT_BTC_1HR_KALSHI_ADMIN_TOKEN=                      # openssl rand -hex 32

# ---- Feed endpoints ----------------------------------------------------------
BOT_BTC_1HR_KALSHI_COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com
# Kraken V2 — confirmation venue. Binance is geo-blocked from US Cloud Run.
BOT_BTC_1HR_KALSHI_KRAKEN_WS_URL=wss://ws.kraken.com/v2

# ---- Economic calendar (structured, not NLP) --------------------------------
BOT_BTC_1HR_KALSHI_CALENDAR_PROVIDER=tradingeconomics
BOT_BTC_1HR_KALSHI_CALENDAR_API_KEY=                 # optional; empty = free tier
BOT_BTC_1HR_KALSHI_CALENDAR_POLL_INTERVAL_SEC=60
BOT_BTC_1HR_KALSHI_CALENDAR_PREEMPT_FLATTEN_SEC=60   # flatten T-60s before high-impact event
BOT_BTC_1HR_KALSHI_CALENDAR_STABILIZE_MIN=30         # no entries for 30m after release

# ---- Risk policy (defaults match docs/RISK.md; tune via weekly param-tune PR)-
BOT_BTC_1HR_KALSHI_BASE_ALLOCATION_PCT=0.02          # 2% of daily margin
BOT_BTC_1HR_KALSHI_MAX_PER_TRADE_PCT=0.05            # 5% hard ceiling
BOT_BTC_1HR_KALSHI_HARD_DRAWDOWN_PCT=0.15            # 15% single-trade loss triggers freeze
BOT_BTC_1HR_KALSHI_DAILY_LOSS_SOFT_PCT=0.05
BOT_BTC_1HR_KALSHI_DAILY_LOSS_HARD_PCT=0.10
BOT_BTC_1HR_KALSHI_MAX_CONCURRENT_POSITIONS=3
BOT_BTC_1HR_KALSHI_MAX_OPEN_ORDERS=10

# ---- Position Monitor (§DESIGN 7.4a) ----------------------------------------
BOT_BTC_1HR_KALSHI_EARLY_CASHOUT_THRESHOLD_CENTS=99   # ≥99¢ → IOC cash-out
BOT_BTC_1HR_KALSHI_SOFT_STOP_FRACTION=0.35            # base; × regime × time multipliers
BOT_BTC_1HR_KALSHI_SOFT_STOP_DEBOUNCE_SEC=2

# ---- Execution ---------------------------------------------------------------
BOT_BTC_1HR_KALSHI_IOC_RUNG1_OFFSET_CENTS=3
BOT_BTC_1HR_KALSHI_IOC_RUNG2_OFFSET_CENTS=6
BOT_BTC_1HR_KALSHI_IOC_RUNG_TIMEOUT_MS=400
BOT_BTC_1HR_KALSHI_ABANDON_THRESHOLD_P_SETTLE=0.60    # abandon when p_settle > this
BOT_BTC_1HR_KALSHI_MAX_CONCURRENT_ABANDONED=1

# ---- Operational breakers ----------------------------------------------------
BOT_BTC_1HR_KALSHI_MAX_CLOCK_DRIFT_MS=250
BOT_BTC_1HR_KALSHI_FEED_STALENESS_MS=2000
BOT_BTC_1HR_KALSHI_RECONCILE_INTERVAL_SEC=60
BOT_BTC_1HR_KALSHI_MAX_SEQ_GAPS_PER_5MIN=3            # triggers feed quarantine

# ---- Observability -----------------------------------------------------------
BOT_BTC_1HR_KALSHI_LOG_LEVEL=INFO
BOT_BTC_1HR_KALSHI_BET_OUTCOMES_LOG_NAME=bot_btc_1hr_kalshi.bet_outcomes
BOT_BTC_1HR_KALSHI_BET_OUTCOMES_BQ_DATASET=bot_btc_1hr_kalshi_bet_outcomes
BOT_BTC_1HR_KALSHI_BET_OUTCOMES_BQ_TABLE=outcomes

# ---- Tick archive ------------------------------------------------------------
BOT_BTC_1HR_KALSHI_TICK_ARCHIVE_BUCKET=               # gs://bot-btc-1hr-kalshi-tick-archive-$PROJECT
BOT_BTC_1HR_KALSHI_TICK_ARCHIVE_FLUSH_INTERVAL_SEC=1800

# ---- Admin HTTP server -------------------------------------------------------
BOT_BTC_1HR_KALSHI_ADMIN_HTTP_PORT=8080
